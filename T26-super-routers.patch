+import { beforeEach, describe, expect, it, vi } from 'vitest'
+
+import {
+  recordAudit,
+  SUPER_ACTIONS,
+  type AuditableContext,
+  type AuditLogInsert,
+} from '../../src/routers/super/_audit-log.js'
+
+interface RecorderState {
+  inserts: AuditLogInsert[]
+  shouldThrow: boolean
