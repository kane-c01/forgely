NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
NEXT_PUBLIC_PLAUSIBLE_SCRIPT_SRC=https://plausible.io/js/script.outbound-links.js

BETTER_STACK_API_TOKEN=
BETTER_STACK_HEARTBEAT_URL=


# === 15. 邮件 (本地 Mailpit / 生产 Resend / 阿里云邮件推送) ================
EMAIL_SMTP_HOST=localhost
EMAIL_SMTP_PORT=1025
EMAIL_SMTP_USER=
EMAIL_SMTP_PASS=
EMAIL_FROM=hello@forgely.cn
RESEND_API_KEY=


# === 16. 应用 URL ==========================================================
NEXT_PUBLIC_APP_URL=http://localhost:3001
NEXT_PUBLIC_WEB_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000
# apps/app：false=关闭演示数据回退与生成页假进度流（生产建议 false）
# NEXT_PUBLIC_FORGELY_DEMO_FALLBACK=false


# === 17. 速率限制覆盖 (可选) ===============================================
RATE_LIMIT_AI_PER_MIN=10
RATE_LIMIT_CREDITS_PER_DAY_STARTER=500


# === 18. Worker / Pipeline 调试 ============================================
FORGELY_WORKER_AUTOBOOT=1
FORGELY_WORKER_CONCURRENCY=2
FORGELY_MOCK_ARTIST=0
