# ──────────────────────────────────────────────────────────────────────────────
# Forgely · 全局环境变量模板
#
# 复制：
#   cp .env.template .env                       # 给 services/api / worker / scripts
#   cp .env.template apps/web/.env.local        # 给 apps/web (Next.js)
#   cp .env.template apps/app/.env.local        # 给 apps/app (Next.js)
#
# 详细申请教程：infra/secrets/README.md
# 任何 NEXT_PUBLIC_* 都会被打包进前端，**不要放秘钥**。
# ──────────────────────────────────────────────────────────────────────────────


# === 1. 运行环境 ============================================================
NODE_ENV=development
APP_VERSION=                              # 可选，部署脚本注入 git sha


# === 2. 数据库 (PolarDB-PG / 本地 Postgres) ================================
DATABASE_URL=postgresql://forgely:forgely@localhost:5432/forgely?schema=public
# 阿里云 PolarDB（Terraform 输出后填）：
POLARDB_CLUSTER_ID=
POLARDB_ACCESS_KEY=
POLARDB_SECRET_KEY=


# === 3. Redis (BullMQ + 速率限制 + sessions) ===============================
REDIS_URL=redis://localhost:6379


# === 4. Auth (NextAuth / 自研 JWT) =========================================
# openssl rand -base64 48
AUTH_SECRET=
AUTH_JWT_ISSUER=forgely.cn
AUTH_JWT_AUDIENCE=forgely-app
AUTH_SESSION_TTL_DAYS=30
NEXTAUTH_URL=http://localhost:3001
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=


# === 5. 中国登录 (微信开放平台 + SMS OTP) ==================================
WECHAT_OPEN_APP_ID=
WECHAT_OPEN_APP_SECRET=
ALIYUN_SMS_ACCESS_KEY=
ALIYUN_SMS_SECRET_KEY=
ALIYUN_SMS_SIGN_NAME=Forgely
ALIYUN_SMS_TEMPLATE_OTP=
TENCENT_SMS_SECRET_ID=
TENCENT_SMS_SECRET_KEY=
TENCENT_SMS_APP_ID=
TENCENT_SMS_SIGN_NAME=Forgely
TENCENT_SMS_TEMPLATE_OTP=


# === 6. 中国收款 (微信支付 V3 + 支付宝) ====================================
WECHAT_PAY_MCH_ID=
WECHAT_PAY_API_V3_KEY=
WECHAT_PAY_PRIVATE_KEY=
WECHAT_PAY_CERT_SERIAL=
WECHAT_PAY_NOTIFY_URL=https://api.forgely.cn/api/payments/wechat/webhook
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_NOTIFY_URL=https://api.forgely.cn/api/payments/alipay/webhook
ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do


# === 7. 海外收款 (Stripe + Stripe Connect) =================================
STRIPE_SECRET_KEY=sk_test_
STRIPE_PUBLISHABLE_KEY=pk_test_
STRIPE_WEBHOOK_SECRET=whsec_
STRIPE_CONNECT_CLIENT_ID=ca_
STRIPE_PORTAL_RETURN_URL=http://localhost:3001/billing
# 订阅价 ID
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_YEARLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_AGENCY_MONTHLY=
STRIPE_PRICE_AGENCY_YEARLY=
# 积分包价 ID
STRIPE_PRICE_CREDIT_MINI=
STRIPE_PRICE_CREDIT_STANDARD=
STRIPE_PRICE_CREDIT_BULK=
STRIPE_PRICE_CREDIT_SCALE=


# === 8. LLM 提供商 =========================================================
DEEPSEEK_API_KEY=
QWEN_API_KEY=
ANTHROPIC_API_KEY=


# === 9. 视频 / 图片 / 3D 生成 ==============================================
VIDU_API_KEY=
KLING_API_KEY=
RUNWAY_API_KEY=
FAL_API_KEY=
IDEOGRAM_API_KEY=
MESHY_API_KEY=


# === 10. 对象存储 (Cloudflare R2 + 阿里云 OSS) =============================
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_ASSETS=forgely-assets
