GOOGLE_SEARCH_CONSOLE_KEY=


# === 13. Scraper / 代理 ====================================================
PROXY_POOL_CN_URL=
SCRAPER_API_KEY=


# === 14. 监控 (空则全部 no-op) =============================================
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
SENTRY_ENV=
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENV=

NEXT_PUBLIC_POSTHOG_KEY=
