{
  "name": "forgely",
  "version": "0.0.0",
  "private": true,
  "description": "Brand operating system for the AI era.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kane-c01/forgely.git"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.12.0",
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel --filter=@forgely/web --filter=@forgely/app --filter=@forgely/storefront",
    "dev:web": "pnpm --filter @forgely/web dev",
    "dev:app": "pnpm --filter @forgely/app dev",
    "dev:storefront": "pnpm --filter @forgely/storefront dev",
    "dev:worker": "pnpm --filter @forgely/worker dev",
    "dev:all": "concurrently -k -n web,app,store,worker -c blue,green,magenta,yellow \"pnpm dev:web\" \"pnpm dev:app\" \"pnpm dev:storefront\" \"REDIS_URL=redis://localhost:6380 DATABASE_URL='postgresql://forgely:forgely@localhost:5433/forgely?schema=public' FORGELY_WORKER_AUTOBOOT=1 FORGELY_MOCK_ARTIST=1 pnpm dev:worker\"",
    "stack:up": "docker compose -f infra/docker/compose.dev.yml up -d",
    "stack:down": "docker compose -f infra/docker/compose.dev.yml down",
    "stack:reset": "docker compose -f infra/docker/compose.dev.yml down -v && pnpm stack:up && sleep 5 && pnpm db:migrate",
    "db:migrate": "pnpm --filter @forgely/api prisma:migrate:deploy",
    "db:push": "pnpm --filter @forgely/api exec prisma db push --skip-generate",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\" --ignore-path .gitignore",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@types/node": "^20.16.10",
    "@typescript-eslint/eslint-plugin": "^8.8.0",
    "@typescript-eslint/parser": "^8.8.0",
    "concurrently": "^9.0.1",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.8",
    "turbo": "^2.1.3",
    "typescript": "^5.6.2"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,yml,yaml,css}": [
      "prettier --write"
    ]
  }
}
