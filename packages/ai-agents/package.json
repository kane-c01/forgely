{
  "name": "@forgely/ai-agents",
  "version": "0.0.0",
  "private": true,
  "description": "AI Agent orchestration (Scraper, Analyzer, Director, Planner, Copywriter, Artist, Compliance)",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./analyzer": {
      "types": "./src/agents/analyzer.ts",
      "import": "./src/agents/analyzer.ts",
      "default": "./src/agents/analyzer.ts"
    },
    "./providers": {
      "types": "./src/providers/index.ts",
      "import": "./src/providers/index.ts",
      "default": "./src/providers/index.ts"
    }
  },
  "scripts": {
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.1",
    "@forgely/scraper": "workspace:*",
    "@forgely/visual-dna": "workspace:*",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.2",
    "typescript": "^5.6.2",
    "vitest": "^2.1.2"
  }
}
