# @forgely/scraper environment variables
#
# Copy to `.env` (or export in your shell) before running the CLI against
# JS-rendered or anti-bot-protected sites (Amazon / 1688 / Taobao / JD).
#
# Free Shopify and WooCommerce stores need NO env at all — try them first.

# https://www.scraperapi.com/
SCRAPERAPI_KEY=

# Optional: override the default ScraperAPI region. Use 'cn' for 1688/Taobao/JD,
# 'us' for Amazon US, 'de' for Amazon Germany, etc.
# SCRAPERAPI_COUNTRY=us

# Optional: when set, the CLI defaults `--site-id` for asset mirroring keys.
# FORGELY_SITE_ID=
