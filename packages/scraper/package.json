{
  "name": "@forgely/scraper",
  "version": "0.0.0",
  "private": true,
  "description": "Multi-source scraper adapters (Shopify / WooCommerce / Amazon / AliExpress / Etsy / Generic AI fallback)",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./adapters/shopify": {
      "types": "./src/adapters/shopify.ts",
      "import": "./src/adapters/shopify.ts",
      "default": "./src/adapters/shopify.ts"
    },
    "./adapters/woocommerce": {
      "types": "./src/adapters/woocommerce.ts",
      "import": "./src/adapters/woocommerce.ts",
      "default": "./src/adapters/woocommerce.ts"
    },
    "./adapters/amazon": {
      "types": "./src/adapters/amazon.ts",
      "import": "./src/adapters/amazon.ts",
      "default": "./src/adapters/amazon.ts"
    },
    "./adapters/aliexpress": {
      "types": "./src/adapters/aliexpress.ts",
      "import": "./src/adapters/aliexpress.ts",
      "default": "./src/adapters/aliexpress.ts"
    },
    "./adapters/etsy": {
      "types": "./src/adapters/etsy.ts",
      "import": "./src/adapters/etsy.ts",
      "default": "./src/adapters/etsy.ts"
    },
    "./adapters/alibaba1688": {
      "types": "./src/adapters/alibaba1688.ts",
      "import": "./src/adapters/alibaba1688.ts",
      "default": "./src/adapters/alibaba1688.ts"
    },
    "./adapters/taobao": {
      "types": "./src/adapters/taobao.ts",
      "import": "./src/adapters/taobao.ts",
      "default": "./src/adapters/taobao.ts"
    },
    "./adapters/jd": {
      "types": "./src/adapters/jd.ts",
      "import": "./src/adapters/jd.ts",
      "default": "./src/adapters/jd.ts"
    },
    "./adapters/generic-ai": {
      "types": "./src/adapters/generic-ai.ts",
      "import": "./src/adapters/generic-ai.ts",
      "default": "./src/adapters/generic-ai.ts"
    },
    "./storage": {
      "types": "./src/storage/index.ts",
      "import": "./src/storage/index.ts",
      "default": "./src/storage/index.ts"
    }
  },
  "scripts": {
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist .turbo coverage"
  },
  "dependencies": {
    "cheerio": "^1.0.0",
    "ulid": "^2.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.16.10",
    "@vitest/coverage-v8": "^2.1.5",
    "msw": "^2.6.0",
    "typescript": "^5.6.2",
    "vitest": "^2.1.5"
  }
}
