{
  "name": "@forgely/scraper-playwright",
  "version": "0.0.0",
  "private": true,
  "description": "Playwright-backed BrowserAdapter for @forgely/scraper (screenshots + JS-rendered HTML)",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist .turbo coverage"
  },
  "dependencies": {
    "@forgely/scraper": "workspace:*",
    "playwright": "^1.48.0"
  },
  "devDependencies": {
    "@types/node": "^20.16.10",
    "@vitest/coverage-v8": "^2.1.5",
    "typescript": "^5.6.2",
    "vitest": "^2.1.5"
  }
}
