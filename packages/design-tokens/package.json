{
  "name": "@forgely/design-tokens",
  "version": "0.0.0",
  "private": true,
  "description": "Forgely Cinematic Industrial design tokens (colors / fonts / spacing / motion) + Tailwind preset shared across all three apps.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./tailwind": {
      "types": "./tailwind.preset.ts",
      "import": "./tailwind.preset.ts",
      "default": "./tailwind.preset.ts"
    },
    "./css": "./src/css-variables.css"
  },
  "files": [
    "src",
    "tailwind.preset.ts"
  ],
  "scripts": {
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "echo \"no tests yet\" && exit 0"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.2"
  }
}
