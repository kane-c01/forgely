{
  "name": "@forgely/worker",
  "version": "0.0.0",
  "private": true,
  "description": "BullMQ workers — runs the end-to-end Forgely generation pipeline + Redis Streams event bus.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./queue": {
      "types": "./src/queue.ts",
      "import": "./src/queue.ts",
      "default": "./src/queue.ts"
    },
    "./cron": {
      "types": "./src/cron.ts",
      "import": "./src/cron.ts",
      "default": "./src/cron.ts"
    }
  },
  "scripts": {
    "dev": "FORGELY_WORKER_AUTOBOOT=1 tsx watch src/index.ts",
    "start": "FORGELY_WORKER_AUTOBOOT=1 tsx src/index.ts",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "echo \"no tests yet\" && exit 0"
  },
  "dependencies": {
    "@forgely/ai-agents": "workspace:*",
    "@forgely/api": "workspace:*",
    "@forgely/deploy": "workspace:*",
    "@forgely/dsl": "workspace:*",
    "@forgely/scraper": "workspace:*",
    "@sentry/node": "^8.42.0",
    "bullmq": "^5.21.2",
    "cron": "^4.4.0",
    "ioredis": "^5.4.1"
  },
  "devDependencies": {
    "@types/cron": "^2.4.3",
    "@types/node": "^20.16.10",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}
