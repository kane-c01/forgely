{
  "name": "@forgely/medusa",
  "version": "0.0.0",
  "private": true,
  "description": "Forgely Medusa v2 commerce backend — multi-tenant, 5 custom modules, 5 payment providers",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "medusa develop",
    "start": "medusa start",
    "build": "medusa build",
    "seed": "medusa exec ./src/scripts/seed.ts",
    "db:setup": "medusa db:setup",
    "db:migrate": "medusa db:migrate",
    "db:generate": "medusa db:generate",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "echo \"medusa: no unit tests yet\" && exit 0"
  },
  "dependencies": {
    "@medusajs/admin-sdk": "^2.13.5",
    "@medusajs/framework": "^2.13.5",
    "@medusajs/medusa": "^2.13.5",
    "@medusajs/medusa-cli": "^2.13.5",
    "@mikro-orm/core": "^6.4.0",
    "@mikro-orm/migrations": "^6.4.0",
    "@mikro-orm/postgresql": "^6.4.0",
    "awilix": "^12.0.0",
    "pg": "^8.13.0",
    "stripe": "^17.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.16.10",
    "typescript": "^5.6.2"
  }
}
