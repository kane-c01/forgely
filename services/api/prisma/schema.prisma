// ─────────────────────────────────────────────────────────────────────────────
// Forgely — Core Database Schema
// Source of truth: docs/MASTER.md §30 (核心表) + §3 (商业模型) + §25 (积分系统)
// Owner: W3 (DB / Auth / Credits / Stripe)
//
// Conventions:
//   - cuid() ids unless externally meaningful (VisualDNA / Plan use slugs)
//   - All money in USD cents (Int)
//   - All credits are integers (no fractional credits)
//   - Soft enums kept as String for forward-compat; constants are codified
//     in src/db.ts (USER_ROLES, PLANS, etc.) and validated at the API layer.
//   - Tenant isolation: every tenant-scoped row has `userId` indexed.
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider        = "prisma-client-js"
  previewFeatures = []
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ════════════════════════════════════════════════════════════════════════════
//  IDENTITY
// ════════════════════════════════════════════════════════════════════════════

/// Application user — covers customers, super admins, internal support agents.
/// Roles: user | super_admin | admin | support
/// Plans: free | starter | pro | agency | enterprise
model User {
  id              String    @id @default(cuid())
  email           String    @unique
  emailVerifiedAt DateTime?
  name            String?
  avatarUrl       String?

  /// Argon2id password hash. Null for OAuth-only users.
  passwordHash String?

  role String @default("user")
  plan String @default("free")

  /// Stripe Customer (cus_xxx) — created lazily on first checkout.
  stripeCustomerId String? @unique

  /// Soft-lock for repeated failed logins.
  failedLoginCount Int       @default(0)
  lockedUntil      DateTime?

  /// 2FA — TOTP secret base32, null until enrolled. super_admin enforced via app layer.
  totpSecret    String?
  totpEnabledAt DateTime?

  /// 手机号 E.164 格式（中国 pivot — docs/PIVOT-CN.md §2）。
  phoneE164         String?   @unique
  phoneVerifiedAt   DateTime?
  /// 微信 UnionId — 跨小程序 / 公众号 / 网站统一身份。
  wechatUnionId     String?   @unique

  /// 国家/区域偏好。`cn` = 国内站默认；`global` = 海外站默认。
  region            String    @default("cn")
  /// UI 语言偏好（zh-CN / zh-HK / zh-TW / en）。
  locale            String    @default("zh-CN")

  /// First-time signup flow (/onboarding) completion timestamp. Null
  /// means the user still owes the onboarding form (middleware redirects).
  onboardedAt       DateTime?
  /// Target markets the user plans to sell to — e.g. ['us','uk','de'].
  /// Picked on /onboarding, used later by planner + compliance. JSON
  /// to give room for future per-market metadata without a migration.
  targetMarkets     Json?
  /// 商家公司名称（/onboarding 采集）。
  companyName       String?
  /// 商家经营类目（/onboarding 选 — 美妆 / 玩具 / 家居 / …）。
  businessCategory  String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations
  credits            UserCredits?
  subscription       Subscription?
  accounts           Account[]
  wechatAccount      WechatAccount?
  sessions           Session[]
  sites              Site[]
  brandKits          BrandKit[]
  conversations      AiConversation[]
  mediaAssets        MediaAsset[]
  scrapeHistory      ScrapeHistory[]
  creditTxns         CreditTransaction[]
  creditReservations CreditReservation[]
  generations        Generation[]
  loginEvents        LoginEvent[]
  phoneOtps          PhoneOtp[]
  notificationPrefs  NotificationPreference?

  @@index([email])
  @@index([role])
  @@index([plan])
  @@index([stripeCustomerId])
  @@index([phoneE164])
  @@index([wechatUnionId])
}

// ─────────────────────────────────────────────────────────────────────────
// NOTIFICATION PREFERENCES (Sprint 3 — user can toggle per-channel emails
// and push from /settings → Notifications. One row per user; default values
// are written lazily on first read so we don't need to backfill.)
// ─────────────────────────────────────────────────────────────────────────

model NotificationPreference {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  emailOrders     Boolean @default(true)
  emailMarketing  Boolean @default(false)
  emailSecurity   Boolean @default(true)
  emailBilling    Boolean @default(true)
  pushEnabled     Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────────────────────
// CN PAYMENTS — pending checkout tracking for WeChat Pay / Alipay (Forgely
// platform billing only, see PIVOT-CN.md §3.1). One row per checkout
// attempt. Status is driven by the corresponding webhook handler:
//   pending → paid (success), expired (timeout), failed (declined),
//             refunded (after a separate Refund row is processed).
// ─────────────────────────────────────────────────────────────────────────

model CnPayment {
  id     String @id @default(cuid())
  userId String

  /// `wechat` | `alipay`
  channel String
  /// `subscription` | `credit_pack`
  kind    String
  /// `pending` | `paid` | `expired` | `failed` | `refunded`
  status  String @default("pending")

  /// References the catalog row (Plan.slug or CreditsPackage.slug).
  itemSlug    String
  /// `monthly` | `yearly` (subscription only).
  cadence     String?
  amountCents Int
  currency    String  @default("CNY")

  /// QR code payload for Native checkout.
  qrCode      String? @db.Text
  /// H5 / PC redirect URL for Wap/Page checkout.
  redirectUrl String? @db.Text

  /// Provider-side identifier (wechat prepay_id / alipay out_trade_no).
  externalId String?
  expiresAt  DateTime
  paidAt     DateTime?

  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@index([channel, externalId])
}

// ─────────────────────────────────────────────────────────────────────────
// CN PIVOT — Wechat OAuth + Phone OTP (docs/PIVOT-CN.md §2)
// ─────────────────────────────────────────────────────────────────────────

/// 微信开放平台 / 公众号 / 小程序的 OAuth 绑定。
/// 一个用户最多绑一条（unique on userId）；UnionId 是跨应用的稳定身份。
model WechatAccount {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// 微信 OpenId（同一应用内唯一）。
  openId      String   @unique
  /// 跨应用唯一身份（绑定主账号的核心）。
  unionId     String   @unique
  /// `web` | `mp` (小程序) | `official` (公众号) | `app`。
  scope       String

  nickname    String?
  avatarUrl   String?
  /// 性别 `0=未知 / 1=男 / 2=女`，微信原始字段。
  sex         Int?
  country     String?
  province    String?
  city        String?

  accessToken         String?  @db.Text
  refreshToken        String?  @db.Text
  accessTokenExpires  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([scope])
}

/// 手机号短信 OTP — 短期 token，登录 / 绑定 / 验证三种用途。
/// `code` 永远以 sha256 散列存储，明文从不入库。
model PhoneOtp {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  phoneE164   String
  /// 用途：login | bind | verify | reset_password
  purpose     String
  /// SHA-256(code) — 校验时再 hash 比对。
  codeHash    String
  /// 已尝试次数（最多 5 次）。
  attempts    Int      @default(0)
  /// 发送方 IP（用于风控）。
  requestIp   String?

  expiresAt   DateTime
  consumedAt  DateTime?
  createdAt   DateTime @default(now())

  @@index([phoneE164, purpose, createdAt])
  @@index([userId])
}

/// Auth.js (NextAuth v5) Prisma Adapter — OAuth account links.
model Account {
  id                String  @id @default(cuid())
  userId            String
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([provider, providerAccountId])
  @@index([userId])
}

/// Auth.js Prisma Adapter — server-side sessions (DB strategy).
/// Forgely also supports JWT sessions; this table backs the "remember device"
/// flow and admin session revocation.
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expires      DateTime

  /// Optional device fingerprinting for security ops UX.
  ipAddress  String?
  userAgent  String?  @db.Text
  createdAt  DateTime @default(now())
  lastSeenAt DateTime @default(now())

  @@index([userId])
  @@index([expires])
}

/// Auth.js Prisma Adapter — magic-link / email verification tokens.
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  createdAt  DateTime @default(now())

  @@unique([identifier, token])
}

/// One-shot password reset tokens (separate from VerificationToken for audit).
model PasswordResetToken {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String    @unique
  expires    DateTime
  consumedAt DateTime?
  ipAddress  String?
  createdAt  DateTime  @default(now())

  @@index([userId])
}

/// Per-login event log — fuels rate-limit + audit + anomaly detection.
model LoginEvent {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  email     String
  /// success | bad_password | unknown_user | locked | mfa_required | mfa_failed
  outcome   String
  ipAddress String?
  userAgent String?  @db.Text
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([email, createdAt])
  @@index([ipAddress, createdAt])
}

// ════════════════════════════════════════════════════════════════════════════
//  SITES / GENERATION
// ════════════════════════════════════════════════════════════════════════════

model Site {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  name         String
  subdomain    String  @unique
  customDomain String? @unique

  /// Hosting region: `auto` (Cloudflare global), `us`, `eu`, `apac`.
  /// Non-auto regions require a SiteHostingAddon subscription (see §6.3).
  hostingRegion String @default("auto")

  status         String  @default("draft")
  sourceUrl      String?
  sourcePlatform String?

  dnaId String?
  dna   VisualDNA? @relation(fields: [dnaId], references: [id])

  heroMomentType String?
  heroProductId  String?

  dsl          Json?
  publishedDsl Json?
  publishedAt  DateTime?

  medusaSalesChannelId String? @unique

  /// Per-site operational settings (storefront-facing config the user manages
  /// from /sites/[id]/settings). Schema is owned by the SiteSettings Zod type
  /// in `services/api/src/router/settings.ts`. Free-form JSON so we can ship
  /// new toggles without a migration. Default to empty `{}` on Site create.
  ///   {
  ///     payments?:  { providers: ['stripe' | 'paypal' | 'apple_pay' | 'google_pay' | 'nowpayments'], stripeAccountId?, paypalEmail?, ... }
  ///     shipping?:  { zones: [{ name, regions: [...], rates: [{ label, amountCents, etaDays }] }] }
  ///     tax?:       { mode: 'auto' | 'manual', defaultRate?, includedInPrice?, regions?: {...} }
  ///     storefront?:{ defaultLocale, enabledLocales: string[], defaultCurrency, supportEmail?, contactPhone?, address? }
  ///   }
  settings Json @default("{}")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  versions          ThemeVersion[]
  generations       Generation[]
  assets            MediaAsset[]
  brandKit          BrandKit?
  pages             Page[]
  installedPlugins  InstalledPlugin[]
  complianceRecords ComplianceRecord[]
  customDomainConfig SiteCustomDomain?
  hostingAddon       SiteHostingAddon?

  @@index([userId, status])
  @@index([status, updatedAt])
  @@index([hostingRegion])
}

// ─────────────────────────────────────────────────────────────────────────
// SITE HOSTING — custom domain verification + region add-on (PIVOT-CN §6.3/§6.4)
// ─────────────────────────────────────────────────────────────────────────

/// Tracks custom domain verification and SSL provisioning for a site.
/// Lifecycle:  pending_verification → verified → ssl_provisioning → active | failed
model SiteCustomDomain {
  id     String @id @default(cuid())
  siteId String @unique
  site   Site   @relation(fields: [siteId], references: [id], onDelete: Cascade)

  domain        String @unique
  /// CNAME target: `{siteId}.forgely.app`
  cnameTarget   String
  /// pending_verification | verified | ssl_provisioning | active | failed | removed
  status        String @default("pending_verification")

  /// Cloudflare for SaaS custom hostname id.
  cfCustomHostnameId String?
  /// SSL certificate status from Cloudflare.
  sslStatus          String?
  /// Last DNS verification check result.
  lastVerifiedAt     DateTime?
  /// Number of verification attempts.
  verifyAttempts     Int      @default(0)

  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([domain])
}

/// Paid add-on for dedicated hosting region (non-auto). One row per site
/// with a non-auto region. Status tracks the billing lifecycle.
model SiteHostingAddon {
  id     String @id @default(cuid())
  siteId String @unique
  site   Site   @relation(fields: [siteId], references: [id], onDelete: Cascade)

  /// `us` | `eu` | `apac`
  region         String
  /// active | past_due | canceled | pending
  status         String @default("pending")
  /// Monthly price in CNY cents.
  priceMonthly   Int    @default(4900)

  /// Payment linkage (WeChat/Alipay CnPayment id or Stripe subscription).
  paymentRef     String?
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([region, status])
}

model ThemeVersion {
  id     String @id @default(cuid())
  siteId String
  site   Site   @relation(fields: [siteId], references: [id], onDelete: Cascade)

  version     Int
  dsl         Json
  description String
  /// ai_chat | visual | import | generated
  editorType  String
  createdBy   String
  createdAt   DateTime @default(now())

  @@unique([siteId, version])
  @@index([siteId, createdAt])
}

model Generation {
  id     String @id @default(cuid())
  siteId String
  site   Site   @relation(fields: [siteId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation(fields: [userId], references: [id])

  /// pending | running | completed | failed | cancelled
  status String

  /// 12-step JSON status. See docs/MASTER.md §13.
  steps Json

  inputData Json
  outputDsl Json?

  creditsCost   Int
  /// FK to a credit reservation; populated once reserved.
  reservationId String? @unique

  durationMs   Int?
  errorMessage String?
  retryCount   Int     @default(0)

  createdAt   DateTime  @default(now())
  startedAt   DateTime?
  completedAt DateTime?

  reservation CreditReservation? @relation(fields: [reservationId], references: [id])
  stepRows    GenerationStep[]

  @@index([siteId, createdAt])
  @@index([userId, status])
  @@index([status, createdAt])
}

model VisualDNA {
  id          String   @id
  name        String
  description String   @db.Text
  spec        Json
  isBuiltin   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sites Site[]
}

model BrandKit {
  id     String  @id @default(cuid())
  userId String
  user   User    @relation(fields: [userId], references: [id])
  siteId String? @unique
  site   Site?   @relation(fields: [siteId], references: [id], onDelete: SetNull)

  name         String
  logoPrimary  String?
  logoVariants Json
  colors       Json
  fonts        Json
  voice        Json
  imageStyle   Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model MediaAsset {
  id     String  @id @default(cuid())
  userId String
  user   User    @relation(fields: [userId], references: [id])
  siteId String?
  site   Site?   @relation(fields: [siteId], references: [id], onDelete: SetNull)

  /// image | video | 3d_model | icon | audio
  type         String
  url          String
  thumbnailUrl String?
  filename     String
  size         Int
  dimensions   Json?
  mimeType     String

  /// uploaded | ai_generated | library
  source    String
  generator String?
  prompt    String?  @db.Text
  tags      String[]
  usedIn    Json?

  createdAt DateTime  @default(now())
  deletedAt DateTime?

  @@index([userId, type])
  @@index([siteId, type])
}

model AiConversation {
  id     String  @id @default(cuid())
  userId String
  user   User    @relation(fields: [userId], references: [id])
  siteId String?

  context  Json
  messages Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, updatedAt])
}

// ════════════════════════════════════════════════════════════════════════════
//  CREDITS  (docs/MASTER.md §25)
// ════════════════════════════════════════════════════════════════════════════

/// Per-user credit wallet. There is exactly one row per user.
/// `balance` = currently spendable. `reserved` = pre-debited but not committed
/// (in-flight generations). `lifetimeEarned` / `lifetimeSpent` are
/// monotonic counters for billing analytics.
model UserCredits {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  balance        Int @default(0)
  reserved       Int @default(0)
  lifetimeEarned Int @default(0)
  lifetimeSpent  Int @default(0)

  /// Concurrency guard for hand-rolled optimistic locking when needed.
  version Int @default(0)

  /// Date (UTC midnight) of the current daily-spend window.
  dailySpendDate  DateTime?
  dailySpentToday Int       @default(0)

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

/// Append-only ledger. Every balance mutation MUST insert a row.
/// `amount` is signed: positive = credit added, negative = debit.
/// `balance` is the post-transaction wallet balance (spendable, not reserved).
model CreditTransaction {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// purchase | subscription | consumption | refund | gift | promotion | reservation_release | adjustment
  type    String
  amount  Int
  balance Int

  description String
  metadata    Json?

  /// Optional links for traceability.
  reservationId String?
  reservation   CreditReservation? @relation(fields: [reservationId], references: [id])

  /// Optional Stripe linkage for purchases / refunds.
  stripeEventId  String?
  stripeChargeId String?

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([type, createdAt])
  @@index([stripeChargeId])
}

/// Pre-debit for in-flight long-running operations (generations, batch jobs).
/// `state` lifecycle:  reserved → committed | released | expired
/// On reserve: UserCredits.balance -= amount, UserCredits.reserved += amount.
/// On commit:  UserCredits.reserved -= amount, lifetimeSpent += amount, ledger row.
/// On release: UserCredits.balance += amount, UserCredits.reserved -= amount, ledger row.
model CreditReservation {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  amount      Int
  /// reserved | committed | released | expired
  state       String @default("reserved")
  description String
  metadata    Json?

  expiresAt  DateTime
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?

  transactions CreditTransaction[]
  generation   Generation?

  @@index([userId, state])
  @@index([state, expiresAt])
}

/// Catalog of one-shot top-up packages.
model CreditsPackage {
  id            String   @id @default(cuid())
  /// Stable slug for code references (e.g. "mini" / "standard" / "bulk" / "scale").
  slug          String   @unique
  name          String
  credits       Int
  bonusCredits  Int      @default(0)
  /// Price in USD cents.
  priceUsd      Int
  popular       Boolean  @default(false)
  active        Boolean  @default(true)
  stripePriceId String   @unique
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ════════════════════════════════════════════════════════════════════════════
//  SUBSCRIPTIONS  (docs/MASTER.md §3 + §28)
// ════════════════════════════════════════════════════════════════════════════

/// Plan catalog (drives both UI Pricing tables and Stripe sync).
/// MVP plans: starter / pro / agency. Free is implied (no row needed).
model Plan {
  id                   String   @id @default(cuid())
  /// Slug used in code & on User.plan. (free | starter | pro | agency | enterprise)
  slug                 String   @unique
  name                 String
  /// Monthly USD cents.
  priceMonthlyUsd      Int
  /// Yearly USD cents (already discounted).
  priceYearlyUsd       Int
  /// Monthly granted credits (resets each invoice cycle).
  monthlyCredits       Int
  /// Quotas
  maxSites             Int
  maxCustomDomains     Int
  enable3D             Boolean  @default(false)
  enableAiCopilot      Boolean  @default(false)
  enableCodeExport     Boolean  @default(false)
  /// Whitelabel / custom features
  features             Json?
  active               Boolean  @default(true)
  /// Stripe linkage
  stripeProductId      String?  @unique
  stripePriceMonthlyId String?  @unique
  stripePriceYearlyId  String?  @unique
  sortOrder            Int      @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model Subscription {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  /// starter | pro | agency | enterprise
  plan   String
  /// active | past_due | canceled | trialing | incomplete | unpaid
  status String

  stripeSubscriptionId String @unique
  stripePriceId        String
  /// monthly | yearly
  cadence              String

  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelAtPeriodEnd  Boolean   @default(false)
  trialEndsAt        DateTime?
  canceledAt         DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, currentPeriodEnd])
}

/// Stripe webhook idempotency log. Insert-on-receive; if the unique
/// constraint fires we know we've already processed this event.
model StripeEventLog {
  id            String    @id @default(cuid())
  /// Stripe `evt_xxx`.
  stripeEventId String    @unique
  type          String
  apiVersion    String?
  livemode      Boolean
  payload       Json
  processedAt   DateTime?
  status        String    @default("received") /// received | processed | failed
  error         String?   @db.Text
  attempts      Int       @default(0)
  createdAt     DateTime  @default(now())

  @@index([type, createdAt])
  @@index([status, createdAt])
}

/// Idempotency keys for our outbound Stripe API calls (checkout etc.).
model StripeIdempotencyKey {
  key       String   @id
  scope     String
  userId    String?
  result    Json?
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([scope, createdAt])
  @@index([expiresAt])
}

// ════════════════════════════════════════════════════════════════════════════
//  RATE LIMITS / ABUSE
// ════════════════════════════════════════════════════════════════════════════

/// Sliding-window counters for sensitive endpoints (ai.* / credits.consume / signup).
/// Persistent fallback when Redis is unavailable.
model RateLimitWindow {
  id          String   @id @default(cuid())
  /// Composite key, e.g. "ai:userId:60s" — see src/credits/rate-limit.ts.
  bucketKey   String
  windowStart DateTime
  count       Int      @default(0)
  updatedAt   DateTime @updatedAt

  @@unique([bucketKey, windowStart])
  @@index([windowStart])
}

// ════════════════════════════════════════════════════════════════════════════
//  CMS / PLUGINS
// ════════════════════════════════════════════════════════════════════════════

model InstalledPlugin {
  id          String   @id @default(cuid())
  siteId      String
  site        Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  pluginId    String
  version     String
  /// Encrypted at the application layer (KMS).
  config      Json
  enabled     Boolean  @default(true)
  installedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([siteId, pluginId])
}

model Page {
  id             String    @id @default(cuid())
  siteId         String
  site           Site      @relation(fields: [siteId], references: [id], onDelete: Cascade)
  /// page | blog | legal
  type           String
  slug           String
  title          String
  content        Json
  featuredImage  String?
  seoTitle       String?
  seoDescription String?   @db.Text
  seoKeywords    String[]
  /// draft | published | scheduled
  status         String
  publishedAt    DateTime?
  scheduledFor   DateTime?
  author         String?
  tags           String[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([siteId, slug])
  @@index([siteId, status])
  @@index([type, status])
}

// ════════════════════════════════════════════════════════════════════════════
//  SCRAPER
// ════════════════════════════════════════════════════════════════════════════

model ScraperRule {
  id          String   @id @default(cuid())
  hostname    String   @unique
  selectors   Json
  successRate Float
  lastUsedAt  DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ScrapeHistory {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  sourceUrl    String
  platform     String?
  /// pending | success | failed
  status       String
  productCount Int      @default(0)
  errorMessage String?  @db.Text
  rawData      Json?
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([userId, createdAt])
  @@index([sourceUrl])
}

// ════════════════════════════════════════════════════════════════════════════
//  AUDIT / COMPLIANCE / WAITLIST
// ════════════════════════════════════════════════════════════════════════════

model AuditLog {
  id         String   @id @default(cuid())
  /// super_admin | user | system
  actorType  String
  actorId    String
  action     String
  targetType String
  targetId   String
  before     Json?
  after      Json?
  reason     String?  @db.Text
  ipAddress  String?
  userAgent  String?  @db.Text
  createdAt  DateTime @default(now())

  @@index([actorId, createdAt])
  @@index([action, createdAt])
  @@index([targetType, targetId])
}

model ComplianceRecord {
  id         String    @id @default(cuid())
  siteId     String
  site       Site      @relation(fields: [siteId], references: [id], onDelete: Cascade)
  pageId     String?
  /// info | warning | critical
  severity   String
  rule       String
  content    String    @db.Text
  suggestion String    @db.Text
  /// open | resolved | ignored
  status     String
  resolvedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([siteId, status])
  @@index([severity, status])
}

/// Marketing waitlist (T07 home page captures emails before launch).
model Waitlist {
  id        String    @id @default(cuid())
  email     String    @unique
  source    String?
  referral  String?
  utm       Json?
  invitedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([source, createdAt])
}

// ════════════════════════════════════════════════════════════════════════════
//  COUPONS  (Promotional codes — independent of Stripe coupon ids so we can
//  redeem against credit packs / subscriptions / one-shot services from one
//  catalog. Stripe coupon id is captured when applicable so the discount
//  is applied at the Stripe layer too.)
// ════════════════════════════════════════════════════════════════════════════

model Coupon {
  id              String    @id @default(cuid())
  /// Human-typed code (uppercase). Unique. e.g. "LAUNCH50" / "FRIEND10"
  code            String    @unique
  description     String?
  /// percent_off | amount_off
  discountType    String
  /// 1..100 when discountType = percent_off; cents when amount_off.
  discountValue   Int
  /// What this coupon can be used against:
  /// subscription | credit_pack | service | any
  appliesTo       String    @default("any")
  currency        String    @default("usd")
  /// Optional Stripe coupon id (cou_xxx) for native Stripe redemption.
  stripeCouponId  String?
  /// Per-coupon redemption cap. Null = unlimited.
  maxRedemptions  Int?
  /// Per-user redemption cap.
  maxPerUser      Int?
  redemptions     Int       @default(0)
  startsAt        DateTime?
  expiresAt       DateTime?
  active          Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  redemptionsLog  CouponRedemption[]

  @@index([active, expiresAt])
}

model CouponRedemption {
  id         String   @id @default(cuid())
  couponId   String
  coupon     Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  userId     String
  /// stripe_session_id / stripe_subscription_id / "service:..." etc.
  context    String
  amountOffUsd Int     @default(0)
  createdAt  DateTime @default(now())

  @@index([couponId, createdAt])
  @@index([userId, createdAt])
}

// ════════════════════════════════════════════════════════════════════════════
//  TEAMS  (S3 — multi-seat ownership inside a single tenant. The site's
//  primary owner is still User; team members are auxiliary collaborators
//  with one of three roles. Invitation flow:  invitedAt -> acceptedAt.)
// ════════════════════════════════════════════════════════════════════════════

model TeamMember {
  id          String    @id @default(cuid())
  /// Tenant this membership belongs to (the owning user's id).
  ownerUserId String
  /// Resolved User row when the invite is accepted; null while pending.
  userId      String?
  email       String
  /// OWNER | ADMIN | SUPPORT
  role        String    @default("SUPPORT")
  invitedBy   String?
  invitedAt   DateTime  @default(now())
  acceptedAt  DateTime?
  revokedAt   DateTime?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([ownerUserId, email])
  @@index([ownerUserId, role])
  @@index([userId])
}

// ════════════════════════════════════════════════════════════════════════════
//  REFUNDS  (S3 — explicit refund workflow distinct from CreditTransaction.
//  Operator submits a Refund row; once approved/processed we either issue a
//  Stripe refund OR a credit clawback, and write the matching ledger row.)
// ════════════════════════════════════════════════════════════════════════════

model Refund {
  id          String    @id @default(cuid())
  orderId     String?
  userId      String
  /// USD cents.
  amountCents Int
  /// queued | approved | denied | completed | failed
  status      String    @default("queued")
  reason      String    @db.Text
  /// Stripe refund id (re_xxx) / wechat refund_id / alipay refund_no.
  externalId  String?
  /// stripe | wechat | alipay | manual
  provider    String    @default("stripe")
  metadata    Json?
  createdAt   DateTime  @default(now())
  processedAt DateTime?

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@index([provider, externalId])
}

// ════════════════════════════════════════════════════════════════════════════
//  GENERATION STEPS  (S3 — replaces the JSON `Generation.steps` blob with a
//  proper child table so we can index on per-step status and stream progress
//  to the UI without rewriting the parent row.)
// ════════════════════════════════════════════════════════════════════════════

model GenerationStep {
  id            String     @id @default(cuid())
  generationId  String
  generation    Generation @relation(fields: [generationId], references: [id], onDelete: Cascade)
  /// scrape | analyze | direct | plan | copy | art | compliance | seo | compile | deploy | …
  stepName      String
  /// pending | running | completed | failed | skipped
  status        String     @default("pending")
  /// Sequence index for ordered progress UI.
  ordinal       Int        @default(0)
  startedAt     DateTime?
  completedAt   DateTime?
  durationMs    Int?
  errorMessage  String?    @db.Text
  payload       Json?

  @@index([generationId, ordinal])
  @@index([status, startedAt])
}

// ════════════════════════════════════════════════════════════════════════════
//  W7 Sprint 3 — super-admin enrichment models
//  Added by W7 (T26 / Sprint 3) for the /super console.
//  Migration: run `pnpm prisma:migrate` (W3 owns the migration commit).
// ════════════════════════════════════════════════════════════════════════════

/// Time-boxed impersonation grant. The super-admin requests one; the
/// target user must approve it before a JWT can be issued. The ticket
/// (and the JWT) expire 30 minutes after creation.
///
/// Lifecycle:  awaiting_user → granted | denied | expired | consumed
model LoginAsTicket {
  id              String    @id @default(cuid())
  /// super-admin who initiated the request.
  requestedBy     String
  /// user being impersonated.
  targetUserId    String
  /// awaiting_user | granted | denied | expired | consumed
  status          String    @default("awaiting_user")
  reason          String    @db.Text
  /// Hash of the impersonation JWT — for revocation. We never store the
  /// raw token. Populated after the target user grants access.
  jwtHash         String?
  ipAddress       String?
  userAgent       String?   @db.Text
  createdAt       DateTime  @default(now())
  expiresAt       DateTime
  decidedAt       DateTime?
  consumedAt      DateTime?

  @@index([requestedBy, createdAt])
  @@index([targetUserId, status])
  @@index([status, expiresAt])
}

/// Outbound email campaign launched from /super/marketing.
/// Provider can be Klaviyo, Mailchimp, Resend, or "internal" SMTP.
model EmailCampaign {
  id          String    @id @default(cuid())
  name        String
  /// klaviyo | mailchimp | resend | internal
  provider    String    @default("resend")
  /// draft | queued | sending | sent | failed | scheduled
  status      String    @default("draft")
  subject     String
  /// Body in MJML / Markdown / HTML — provider determines the renderer.
  body        String    @db.Text
  /// Audience targeting in JSON (segment id, plan filter, country, etc.).
  audience    Json
  /// Estimated audience size at last preview.
  audienceSize Int      @default(0)
  /// `delivered`, `opens`, `clicks`, `bounces`, `unsubscribes`.
  stats       Json?
  scheduledAt DateTime?
  sentAt      DateTime?
  createdBy   String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status, scheduledAt])
  @@index([provider, status])
}

/// Platform-wide settings — single-row "singleton" pattern. The seed
/// script or the first `/super/settings` visit inserts the row; every
/// subsequent save is an update (see services/api/src/router/super/settings.ts).
model PlatformSetting {
  id              String   @id @default("singleton")
  platformName    String   @default("Forgely")
  platformDomain  String   @default("forgely.cn")
  defaultLocale   String   @default("zh-CN")
  defaultRegion   String   @default("cn")
  maintenanceMode Boolean  @default(false)
  signupEnabled   Boolean  @default(true)
  /// Free-form JSON blob for future settings we don't want migrations for.
  extra           Json?
  updatedAt       DateTime @updatedAt
  updatedBy       String?
}

/// Platform feature flag. Each row is one boolean toggle surfaced in
/// /super/settings > Feature Flags. `id` is the same string the UI /
/// backend uses (wechatLogin, phoneOtp, wechatPay, …).
model PlatformFeatureFlag {
  id                  String   @id
  enabled             Boolean  @default(false)
  /// True when a working .env credential is required for the flag to
  /// actually take effect at runtime (purely informational for the UI).
  requiresCredential  Boolean  @default(false)
  updatedAt           DateTime @updatedAt
  updatedBy           String?
}

/// Super-admin-visible secret. The real value lives in `.env` (the
/// production deploy uses a Secrets Manager). This row stores ONLY a
/// masked preview + rotation history so a super-admin can see which
/// provider is configured without the backend serving the plaintext.
/// Rotation is an audit-logged event; applying the value to runtime
/// still needs an env deploy.
model PlatformSecret {
  /// Matches the .env key name (e.g. `DEEPSEEK_API_KEY`).
  envVar         String   @id
  /// Human label (DeepSeek / 通义千问 / ...).
  label          String
  /// Masked preview — first 2 + last 4 characters with dots in between.
  maskedPreview  String?
  configured     Boolean  @default(false)
  rotatedAt      DateTime?
  rotatedBy      String?
  updatedAt      DateTime @updatedAt
}

/// Direct push (web push, in-app, optional WeChat / Mini-App template
/// message). Distinct from EmailCampaign because the lifecycle and
/// per-channel quotas differ.
model PushBroadcast {
  id          String    @id @default(cuid())
  /// webpush | inapp | wechat_template | system_banner
  channel     String
  title       String
  body        String    @db.Text
  /// JSON segment definition.
  audience    Json
  audienceSize Int      @default(0)
  /// queued | sending | sent | failed
  status      String    @default("queued")
  scheduledAt DateTime?
  sentAt      DateTime?
  createdBy   String
  createdAt   DateTime  @default(now())

  @@index([status, scheduledAt])
  @@index([channel, status])
}
