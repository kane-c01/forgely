# ─────────────────────────────────────────────────────────────
# Forgely Core API — Environment Variables (W3)
# Copy to `.env` (gitignored) and fill in real values for local dev.
# ─────────────────────────────────────────────────────────────

# ── Database ────────────────────────────────────────────────
DATABASE_URL="postgresql://forgely:forgely@localhost:5432/forgely?schema=public"

# ── Redis (BullMQ + rate limiter + sessions) ───────────────
REDIS_URL="redis://localhost:6379"

# ── Auth ────────────────────────────────────────────────────
# 32+ char random string. Generate: `openssl rand -base64 48`
AUTH_SECRET="change_me_in_production_with_a_long_random_string_min_32_chars"
AUTH_JWT_ISSUER="forgely.app"
AUTH_JWT_AUDIENCE="forgely-app"
AUTH_SESSION_TTL_DAYS="30"

# OAuth (wired in apps/app NextAuth in W6; T06 only emits the adapter tables)
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""

# ── Stripe ──────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PORTAL_RETURN_URL="http://localhost:3001/billing"

# Subscription Price IDs (created in Stripe dashboard).
# 3 plans × 2 cadences = 6 IDs.
STRIPE_PRICE_STARTER_MONTHLY=""
STRIPE_PRICE_STARTER_YEARLY=""
STRIPE_PRICE_PRO_MONTHLY=""
STRIPE_PRICE_PRO_YEARLY=""
STRIPE_PRICE_AGENCY_MONTHLY=""
STRIPE_PRICE_AGENCY_YEARLY=""

# Credit-package Price IDs (4 packs).
STRIPE_PRICE_CREDIT_MINI=""
STRIPE_PRICE_CREDIT_STANDARD=""
STRIPE_PRICE_CREDIT_BULK=""
STRIPE_PRICE_CREDIT_SCALE=""

# ── App URLs ────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3001"
NEXT_PUBLIC_WEB_URL="http://localhost:3000"

# ── Rate-limit overrides (optional) ────────────────────────
RATE_LIMIT_AI_PER_MIN="10"
RATE_LIMIT_CREDITS_PER_DAY_STARTER="500"

# ── AI providers (used by W1/W4 — kept here for env consolidation) ──
ANTHROPIC_API_KEY=""
KLING_API_KEY=""
RUNWAY_API_KEY=""
FAL_API_KEY=""
IDEOGRAM_API_KEY=""
MESHY_API_KEY=""
SCRAPER_API_KEY=""
DATAFORSEO_LOGIN=""
DATAFORSEO_PASSWORD=""

# ── Storage (Cloudflare R2) ────────────────────────────────
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_ASSETS="forgely-assets"
