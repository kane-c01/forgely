# Override the script URL when self-hosting Plausible.
NEXT_PUBLIC_PLAUSIBLE_SCRIPT_SRC=https://plausible.io/js/script.outbound-links.js

# Reserved for future extension (PostHog session replay etc.).
NEXT_PUBLIC_POSTHOG_KEY=

DATABASE_URL=
