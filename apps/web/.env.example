NEXT_PUBLIC_APP_URL=https://forgely.com
# B 端控制台（apps/app）。生产填线上域名；本地双开 web:3000 + app:3001 时可省略，开发环境会默认 http://localhost:3001
NEXT_PUBLIC_APP_DASH_URL=https://app.forgely.com
# 本地示例（与 apps/app/package.json 端口一致）：
# NEXT_PUBLIC_APP_DASH_URL=http://localhost:3001

# Analytics — leave empty in dev so no script is loaded.
# T27e: Plausible (cookieless, GDPR-friendly) is the default provider.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
# Override the script URL when self-hosting Plausible.
NEXT_PUBLIC_PLAUSIBLE_SCRIPT_SRC=https://plausible.io/js/script.outbound-links.js

# Reserved for future extension (PostHog session replay etc.).
NEXT_PUBLIC_POSTHOG_KEY=

DATABASE_URL=
