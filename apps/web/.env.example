NEXT_PUBLIC_APP_URL=https://forgely.com
NEXT_PUBLIC_APP_DASH_URL=https://app.forgely.com

# Analytics — leave empty in dev so no script is loaded.
# T27e: Plausible (cookieless, GDPR-friendly) is the default provider.
